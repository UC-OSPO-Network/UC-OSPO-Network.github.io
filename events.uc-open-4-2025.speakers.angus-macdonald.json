{"version":3,"kind":"Article","sha256":"bf621d2f8a9a39e6c3960d3b040d72d2e6f9772cd1da83c892128db7c58a7e27","slug":"events.uc-open-4-2025.speakers.angus-macdonald","location":"/events/uc-open-4-2025/speakers/angus-macdonald.md","dependencies":[],"frontmatter":{"title":"Angus MacDonald","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/angus-macdonald.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/angus-macdonald.md","thumbnail":"/build/angus-macdonald-2f0699fc3235ab9ba84fcee4751e94ef.jpg","exports":[{"format":"md","filename":"angus-macdonald.md","url":"/build/angus-macdonald-bd79c3124ddcad9dfa8243fd7af8ee60.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/angus-macdonald-2f0699fc3235ab9ba84fcee4751e94ef.jpg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"R3HWPCdjQX","urlSource":"headshots/angus-macdonald.jpg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Angus MacDonald is the lead intellectual property lawyer at UC Legal and has been working at UC’s Office of the President since 2013. His practice primarily focuses on copyright and trademark matters throughout the UC system.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"OLKM2vNMQs"}],"key":"Onkoqp78fF"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"He also manages a team of UC Legal lawyers focused on intellectual property, investments, corporate transactions, and related subject matter.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"qOufDIdtaA"}],"key":"qOu4JixvGN"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"For 7 years, Angus has been leading or co-leading the monthly copyright calls of the State Bar of California, and he also chairs two other copyright-related committees within UC.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"uxtAHwYaS2"}],"key":"cXXPh0ICu8"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Angus was also a member of UC’s systemwide Open Source Software workgroup, which was formed in 2017 to provide guidance to the University’s OSS users and contributors regarding various OSS licenses used in the University environment. The workgroup’s output includes an Open Source Software Chart and several guidance documents. These materials are available on UCOP’s webpage\n","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Ft8XhDYatu"},{"type":"link","url":"https://security.ucop.edu/resources/open-source-software-licensing.html","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Open Source Software (OSS) Resources","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"qZGmOlD4nx"}],"urlSource":"https://security.ucop.edu/resources/open-source-software-licensing.html","key":"zctheBqx47"},{"type":"text","value":".","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"xIZwD4fZ8H"}],"key":"C4p0CtsNya"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Fy7L7LPiiQ"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"xAO8ov5VFN"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"en