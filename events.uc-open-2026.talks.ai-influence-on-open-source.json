{"version":3,"kind":"Article","sha256":"f811aa6e55bb827a0e91efb4af3b9319147a5aa555db99c5ab5752fa91cf8a91","slug":"events.uc-open-2026.talks.ai-influence-on-open-source","location":"/events/uc-open-2026/talks/ai-influence-on-open-source.md","dependencies":[],"frontmatter":{"title":"Influence of AI on Open Source and Open Scholarship","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/ai-influence-on-open-source.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/ai-influence-on-open-source.md","thumbnail":"/uc-ospo-network.github.io/build/fernando-perez-d0ca98e52bca119781000b9fc49d4a50.png","exports":[{"format":"md","filename":"ai-influence-on-open-source.md","url":"/uc-ospo-network.github.io/build/ai-influence-on-open-a1fc171310794c80e16ecc04690d1f13.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"z6Fdu1x0pL"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"o9HlFHcqfj"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Details coming soon.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"XOt9Fv80Xo"}],"key":"Oso9YtaMJK"}],"key":"MXbmoMoJQf"},{"type":"thematicBreak","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"DxnELRatuK"},{"type":"div","children":[{"type":"image","url":"/uc-ospo-network.github.io/build/fernando-perez-d0ca98e52bca119781000b9fc49d4a50.png","alt":"Fernando Perez","align":"center","class":"speaker-bio-img","key":"ScdWU2XmCm","urlSource":"./speaker-headshots/fernando-perez.png"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Fernando Perez | UC Berkeley","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"qeGCmasoNn"}],"identifier":"fernando-perez-uc-berkeley","label":"Fernando Perez | UC Berkeley","html_id":"fernando-perez-uc-berkeley","implicit":true,"key":"aaCrHHML4H"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Fernando Perez is an Associate Professor of Statistics at UC Berkeley, a faculty scientist at Lawrence Berkeley National Laboratory, and the Faculty Director of the Berkeley Institute for Data Science. He created IPython while a graduate student in 2001 and co-founded its successor, Project Jupyter. His research focuses on the intersection of interactive computing, open science, and AI-based tools for science, with a particular focus on questions related to the earth’s cryosphere, climate change, and environmental sustainability. He is the recipient of the 2024 Exceptional Public Service Medal from NASA, the 2024 “Champions of Open Science” recognition from the White House Office of Science and Technology Policy, the 2017 ACM Software Systems Award, and the 2012 Award for the Advancement of Free Software from the Free Software Foundation.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"tXkIAf79pg"}],"key":"c2Vc0U0Bxt"}],"class":"speaker-bio","key":"sRDBU8wfRT"},{"type":"div","children":[{"type":"image","url":"/uc-ospo-network.github.io/build/sahiba-chopra-09b2ae2ec5a122040dda5da7ddc5bea3.jpg","alt":"Sahiba Chopra","align":"center","class":"speaker-bio-img","key":"vqHHpNdOe7","urlSource":"./speaker-headshots/sahiba-chopra.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Sahiba Chopra | UC Berkeley","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"j8kbpm86tH"}],"identifier":"sahiba-chopra-uc-berkeley","label":"Sahiba Chopra | UC Berkeley","html_id":"sahiba-chopra-uc-berkeley","implicit":true,"key":"KdjVU8WYkq"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Sahiba Chopra is a PhD candidate in the Management of Organizations group at UC Berkeley Haas School of Business and a Data Science Fellow at the D-Lab. Her research interests lie at the crossroads of technology, innovation, and the labor market, and she is currently exploring questions about how generative AI might transform workplace collaboration. She has a diverse professional background as a data scientist across industries including fintech, cleantech, and media, and holds a BA in Economics and Chinese from the University of Maryland and an MS in Applied Economics from the University of San Francisco.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"XVjd0sJ1tT"}],"key":"yiZmLv2F6e"}],"class":"speaker-bio","key":"GklTWFNAPF"},{"type":"div","children":[{"type":"image","url":"/uc-ospo-network.github.io/build/marit-macarthur-c7ee835f8fad4973063c0d610c8ab866.jpg","alt":"Marit MacArthur","align":"center","class":"speaker-bio-img","key":"HkLmgAUVUI","urlSource":"./speaker-headshots/marit-macarthur.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Marit MacArthur | UC Davis","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"nuIQdq4EWI"}],"identifier":"marit-macarthur-uc-davis","label":"Marit MacArthur | UC Davis","html_id":"marit-macarthur-uc-davis","implicit":true,"key":"hRxVNDJi0W"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"Marit MacArthur is a faculty member in the University Writing Program at UC Davis, where she has taught since 2016. Her research spans AI and writing, digital voice studies, Writing Across the Curriculum, performance studies, cultural analytics and digital humanities, and open-source software development. She is a Principal Investigator for PAIRR (Peer and AI Review + Reflection), a collaborative grant project funded by the California Education Learning Lab, and a co-investigator with the NEH-funded Center for AI and Experimental Futures (CAIEF) at UC Davis.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"FjLtKEkdst"}],"key":"R9ANkMb8Bs"}],"class":"speaker-bio","key":"aAhidj47ar"},{"type":"div","children":[{"type":"heading","depth":3,"position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"Tara Hernandez | UCSC","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"tMP4xl20Mz"}],"identifier":"tara-hernandez-ucsc","label":"Tara Hernandez | UCSC","html_id":"tara-hernandez-ucsc","implicit":true,"key":"zgb0pfyCtL"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"text","value":"Bio coming soon.","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"OoHkEPlTle"}],"key":"R3zCkGA4wP"}],"key":"BP8FC1M14i"}],"class":"speaker-bio","key":"QnqypnWdPT"},{"type":"div","children":[{"type":"heading","depth":3,"position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"Ilkay Altintas | UCSD","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"hc4mmrYZCF"}],"identifier":"ilkay-altintas-ucsd","label":"Ilkay Alti