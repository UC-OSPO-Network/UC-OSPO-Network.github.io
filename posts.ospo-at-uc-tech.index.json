{"version":3,"kind":"Article","sha256":"8768f39925cced1c99e399bf076903c35da78ef5c14d608802b84079e93eba4f","slug":"posts.ospo-at-uc-tech.index","location":"/posts/ospo-at-uc-tech/index.md","dependencies":[],"frontmatter":{"title":"OSPO Network @ UC Tech","description":"UC OSPO hosts two sessions at UC Tech 2024","tags":["davis"],"authors":[{"id":"Laura Langdon","name":"Laura Langdon"}],"date":"2024-12-03","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/posts/ospo-at-uc-tech/index.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/posts/ospo-at-uc-tech/index.md","thumbnail":"/build/2024_UCTech_2-0174436b32024d5e5ceb675c0d92bc17.png","exports":[{"format":"md","filename":"index.md","url":"/build/index-4f94ea343cf152a2400d096f851e3fc4.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/2024_UCTech_2-0174436b32024d5e5ceb675c0d92bc17.png","alt":"Panel of UC OSPO members at UC Tech 2024","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"KMPj2SbGcD","urlSource":"2024_UCTech_2.png"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"The 2024 UC Tech conference—hosted this year at Davis—featured two sessions led by the UC Open Source Program Office (OSPO) Network, bringing together members of the wider UC community to learn what the OSPO Network is and what it has to offer. A panel session gave an introduction to the network, its functions, and the specific on-campus efforts, and a Birds of a Feather session provided an opportunity for the OSPO team to hear from the community about the needs and challenges of different departments (faculty, students, IT, etc.).","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"VfXPyguiAn"}],"key":"jR4jkeJp5k"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Panel Session","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ZBr82sMATj"}],"identifier":"panel-session","label":"Panel Session","html_id":"panel-session","implicit":true,"key":"VJQhiLEyF9"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Facilitated by Jarrod Millman, the panel familiarized participants with OSPO concepts, discussed examples of how OSPOs influence research and learning activities in higher education, and how everyone can participate in forming the UC-wide OSPO Network. Panelists included Jarrod Millman (UC Berkeley), David Minor (UC San Diego), Stephanie Lieggi (UC Santa Cruz), Vessela Ensberg (UC Davis), Amber Budden (UC Santa Barbara), and Tim Dennis (UC Los Angeles).","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"oURPdJ9JBg"}],"key":"H0IhubqolN"},{"type":"heading","depth":3,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Key discussion highlights","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"RR8quV3q1C"}],"identifier":"key-discussion-highlights","label":"Key discussion highlights","html_id":"key-discussion-highlights","implicit":true,"key":"f4HNH7Hvov"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":19,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Institutional Goals: The UC OSPO network, supported by the Sloan Foundation, aims to encourage broader campus participation and support for open-source projects","position":{"start":{"line":19,"column":1},"end":{"line":19,"