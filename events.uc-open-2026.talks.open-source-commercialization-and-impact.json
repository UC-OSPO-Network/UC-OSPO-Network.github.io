{"version":3,"kind":"Article","sha256":"cf10b271aae5dac3bc1c8d685b769901281b1d783461bb2609c7397c0d8d43a4","slug":"events.uc-open-2026.talks.open-source-commercialization-and-impact","location":"/events/uc-open-2026/talks/open-source-commercialization-and-impact.md","dependencies":[],"frontmatter":{"title":"Open Source Commercialization and Impact","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/open-source-commercialization-and-impact.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/open-source-commercialization-and-impact.md","thumbnail":"/build/karla-padilla-eb4ae474e3fdd5de3ae48c5659067965.jpg","exports":[{"format":"md","filename":"open-source-commercialization-and-impact.md","url":"/build/open-source-commerci-3bde61846cbab0c48d6d0e852c1da9ac.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Eam03ipxtd"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"elmQR9Qkhd"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Details coming soon.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"h42VeeU9nQ"}],"key":"vwWeQg2BcJ"}],"key":"RLECywf7ei"},{"type":"thematicBreak","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"WFc4gQmxac"},{"type":"div","children":[{"type":"image","url":"/build/karla-padilla-eb4ae474e3fdd5de3ae48c5659067965.jpg","alt":"Karla Padilla","align":"center","class":"speaker-bio-img","key":"Gq8uV6T7LL","urlSource":"./speaker-headshots/karla-padilla.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Karla Padilla | UCSD","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"VyphSULSry"}],"identifier":"karla-padilla-ucsd","label":"Karla Padilla | UCSD","html_id":"karla-padilla-ucsd","implicit":true,"key":"bMMOeB7OhP"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Karla Padilla is part of the UC San Diego Open Source Program Office. She has 20 years of experience as an attorney in the tech industry. Her experience includes writing the open source policy and procedures for the use, creation and distribution of open source software. These procedures include a review process of inbound as well as outbound code, ensuring license compliance, and the creation of “sandboxes” allowing contributors to make ongoing contributions to a project without review. Additionally, Karla has worked on integration of acquired companies, bringing the acquired company into compliance with the applicable policies and licenses.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"Mo1MvP9ywz"}],"key":"T11LKSE4iC"}],"class":"speaker-bio","key":"o0msZlxiKK"},{"type":"div","children":[{"type":"image","url":"/build/heather-meeker-e0fb0f92cf6a0353e333d3d62b6972bc.jpg","alt":"Heather Meeker","align":"center","class":"speaker-bio-img","key":"wwbiY9A7WC","urlSource":"./speaker-headshots/heather-meeker.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Heather Meeker | Chinstrap Community","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"bGfmmhiWpg"}],"identifier":"heather-meeker-chinstrap-community","label":"Heather Meeker | Chinstrap Community","html_id":"heather-meeker-chinstrap-community","implicit":true,"key":"HVGLTrsvuM"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Heather Meeker is a specialist in open source licensing. She is a partner at Tech Law Partners, LLP, a law firm focused on technology transactions. She is also co-founder of Chinstrap Community, a resource center for investors and founders starting commercial open source businesses. She is also an alumna of UC Berkeley law school.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"T9YFATcX3p"}],"key":"U8nHe9hGNW"}],"class":"speaker-bio","key":"hbrhe85j2o"},{"type":"div","children":[{"type":"image","url":"/build/mike-cohen-afcbd889c3aaeee2adbaec2847e9eb80.jpg","alt":"Mike Cohen","align":"center","class":"speaker-bio-img","key":"XAeUtQKmUL","urlSource":"./speaker-headshots/mike-cohen.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Mike Cohen | UC Berkeley","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"kUU5P3DtgM"}],"identifier":"mike-cohen-uc-berkeley","label":"Mike Cohen | UC Berkeley","html_id":"mike-cohen-uc-berkeley","implicit":true,"key":"megCdK3WLZ"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"As the Director of Innovation Ecosystem Development, Mike drives initiatives and agreements that catalyze the commercialization of UC Berkeley innovations and support the funding of campus research. In this role, Mike has worked with hundreds of startups, and he has spearheaded the commercialization of over 100 innovations in numerous areas, including software and AI models. In 2019, Mike led the development of UC Berkeley’s Open Source Software Startup (OS3) Good-Standing Program that enables the university to obtain stock equity in startups that spin-out of the university leveraging software developed at, and open-sourced by the university.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"Upop0XpEhp"}],"key":"HPA3KOBeOc"}],"class":"speaker-bio","key":"haucCd2jdX"},{"type":"div","children":[{"type":"image","url":"/build/dirk-riehle-5b6e73c30c59338c2a354ca0f6854afb.jpg","alt":"Dirk Riehle","align":"center","class":"speaker-bio-img","key":"g8jY6HACaK","urlSource":"./speaker-headshots/dirk-riehle.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"Dirk Riehle | FAU Erlangen-Nurnberg","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"dq4SeMvQHX"}],"identifier":"dirk-riehle-fau-erlangen-nurnberg","label":"Dirk Riehle | FAU Erlangen-Nurnberg","html_id":"dirk-riehle-fau-erlangen-nurnberg","implicit":true,"key":"tvCM2Na8j4"},{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"Dirk Riehle is a professor of computer science at FAU Erlangen. They are also the CEO of Bayave GmbH, a training and consulting firm. Their work helps companies succeed in and through software, with a specialization in open source, inner source, and product strategy. Before joining academia, Prof. Riehle led the open source research group at SAP Labs in Palo Alto, California (Silicon Valley). They also worked for software startups and large corporations in Boston, MA and Zurich, Switzerland, as a software developer, architect, and engineering manager. Riehle holds a Ph.D. in computer science from ETH Zurich and an M.B.A. from Stanford Graduate School of Business. They welcome email at ","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"eapptuRYKT"},{"type":"link","url":"mailto:dirk@riehle.org","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"dirk@riehle.org","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"Qcj1qTr6YC"}],"urlSource":"mailto:dirk@riehle.org","key":"Px7GgKhbXO"},{"type":"text","value":", blog at ","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"ag3e6ADOgM"},{"type":"link","url":"https://dirkriehle.com","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"dirkriehle.com","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"Fx9KkpAIAL"}],"urlSource":"https://dirkriehle.com","key":"b9ZHuBt47T"},{"type":"text","value":", and tweet as ","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"F17a32s7f8"},{"type":"link","url":"https://twitter.com/dirkriehle","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"@dirkriehle","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"ypwxN97U3g"}],"urlSource":"https://twitter.com/dirkriehle","key":"t0uUT4TNPn"},{"type":"text","value":".","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"Vv7MErfspM"}],"key":"Ttd1VdgFgb"}],"class":"speaker-bio","key":"YnNAqgGU81"},{"type":"div","children":[{"type":"image","url":"/build/joel-kehle-e211cbd585d25a4ed12b3a77cd1fff36.jpg","alt":"Joel Kehle","align":"center","class":"speaker-bio-img","key":"MVzPqpZjAp","urlSource":"./speaker-headshots/joel-kehle.jpg"},{"type":"heading","depth":3,"position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"children":[{"type":"text","value":"Joel Kehle | UCLA","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"h9HbgN195U"}],"identifier":"joel-kehle-ucla","label":"Joel Kehle | UCLA","html_id":"joel-kehle-ucla","implicit":true,"key":"vA84OUXXOP"},{"type":"paragraph","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"Joel Kehle is a Business Development Officer at UCLA Technology Development Group, where he manages a portfolio of database, algorithm, artificial intelligence, bioinformatics, and other computer science technologies. With over 20 years of industry experience, Joel spent more than a decade at Qualcomm focused on cloud computing, enterprise architecture, infrastructure automation, and middleware software. He previously served as Vice President, Technology for multiple startup companies incubated at Idealab in Los Angeles. Joel holds a Bachelor of Science in Computer Science from MIT and an MBA from UCLA Anderson School of Management.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"RJFIKfkYb7"}],"key":"ucaVe8zr63"}],"class":"speaker-bio","key":"XvvpSfkxXj"}],"key":"ysM1mv3s2u"}],"key":"TAnlNJbRxc"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}