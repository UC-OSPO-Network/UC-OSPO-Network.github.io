{"version":3,"kind":"Article","sha256":"0ac4de9e83753dc59e519a90ea3bd6f0746ce8e9715a8d5927a445612feb1e34","slug":"santa-barbara.index","location":"/santa-barbara/index.md","dependencies":[],"frontmatter":{"title":"UC Santa Barbara Open Source Program","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":2}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/santa-barbara/index.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/santa-barbara/index.md","thumbnail":"/build/library2_1600-4b4cfd5071a3001331da6b942ed4aa41.jpg","exports":[{"format":"md","filename":"index.md","url":"/build/index-2ed01f8be45c0776a53600069c76965c.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"comment","value":" HERO IMAGE ","key":"dLtriGyEqU"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/library2_1600-4b4cfd5071a3001331da6b942ed4aa41.jpg","alt":"UCSB library exterior","key":"bujyDSKT34","urlSource":"../static/images/ucsb/library2_1600.jpg"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Image courtesy of UCSB","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"WVz5hnNDD6"}],"key":"pkgn6pI5hD"}],"key":"axWYE8px44"}],"key":"pVG0ni6Hqi"}],"class":"ucsb-hero-img","enumerator":"1","key":"M04gVQokoR"},{"type":"heading","depth":2,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"About us","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"Vv3z6sMgXy"}],"identifier":"about-us","label":"About us","html_id":"about-us","implicit":true,"key":"sdAaQj7Fq7"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"UC Santa Barbara has a strong history of leadership and innovation in open\nsource software development and open science. However, expertise and resources\nhave traditionally been distributed across various parts of the campus. The Open\nSource Programs Team at UCSB serves as a central hub, bringing together open\nsource activities, expertise, and community connections.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"LZDep5uJUD"}],"key":"hMDNXKI1fL"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"UC Santa Barbara is a proud partner in the UC OSPO Network, collaborating\nalongside five other UC campuses. Our support for both the UCSB community and\nthe broader network includes:","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"Wr0KqIpUU6"}],"key":"bw6xkVrGVm"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":26,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Identifying and cataloging open source projects developed at UC campuses","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"t4ayLucSLM"}],"key":"rU91fS1kiC"}],"key":"izescdJOJz"},{"type":"listItem","spread":true,"position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Creating educational materials, curricula, and best practice guidelines","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"uGAb1Gvhkx"}],"key":"eIlV4jKWtf"}],"key":"pz7h0DFtxj"},{"type":"listItem","spread":true,"position":{"start":{"line":28,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Offering services and resources aimed at ensuring the sustainability of open\nsource projects","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"vsFCi4E08i"}],"key":"SpDklJixBb"}],"key":"lq4CSICUL5"}],"key":"cIPfTe3lLz"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"If you’d like to keep up with our activities, please consider joining our\nmailing list, which includes a monthly newsletter and occasional announcements.\nYou can unsubscribe at any time.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"wUzJkTufYG"}],"key":"yeLnJ0IlZr"},{"type":"comment","value":" BUTTON: JOIN OUR MAILING LIST ","key":"HIobBJtkMs"},{"type":"div","children":[{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"link","class":"btn-ucsb-primary","url":"https://signup.e2ma.net/signup/2045162/1984731/","children":[{"type":"text","value":"Join our mailing list","key":"BSn3zTjczn"}],"urlSource":"https://signup.e2ma.net/signup/2045162/1984731/","key":"BwDBo9wBSS"}],"key":"TihF2WPz92"}],"class":"btn-center-wrapper","key":"eqS6cTsYIs"},{"type":"comment","value":" CURRENT PROJECTS ","key":"CU0AQoA8IF"},{"type":"div","children":[{"type":"card","children":[{"type":"cardTitle","children":[{"type":"text","value":"Current projects","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"H8mzYb8VsR"}],"key":"kzZZbEqFVK"},{"type":"heading","depth":3,"position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"UCSB Open Source Meetup","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"h4lao4lBNm"}],"identifier":"ucsb-open-source-meetup","label":"UCSB Open Source Meetup","html_id":"ucsb-open-source-meetup","implicit":true,"key":"sR7iIUgMVg"},{"type":"div","children":[{"type":"image","url":"/build/ucsb_meetup-a620f3030c83df5eace19bf8534d51fc.png","alt":"UCSB students working on laptops in a group setting","align":"center","key":"Ln009FmlGi","urlSource":"../static/images/ucsb/ucsb_meetup.png"}],"class":"ucsb-float-right","key":"xO5DB5fALu"},{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Once a month, the UCSB Open Source Programs Team hosts a casual, virtual, open\nsource meetup. The meetup is open to UCSB students, faculty, and staff of all\nbackgrounds and experience levels. The format rotates between attendee-led\ndiscussions and the “Open Source Lounge”, a coworking group where we tackle our\nindividual open source goals. This is a great opportunity to meet others\ninterested in open source, share tips and experiences, and be a part of a larger\nopen source community at UCSB.","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"rYFCuasG0q"}],"key":"b0GPQV3QHL"},{"type":"div","children":[{"type":"paragraph","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"link","class":"btn-ucsb-secondary","url":"/santa-barbara/ucsb-projects/meetup","children":[{"type":"text","value":"Visit the meetup webpage!","key":"UgysLlp23K"}],"urlSource":"/santa-barbara/ucsb-projects/meetup","dataUrl":"/santa-barbara.ucsb-projects.meetup.json","internal":true,"protocol":"file","key":"jchrpcVxn1"}],"key":"DIW01B1T1x"}],"class":"btn-center-wrapper","key":"MF2ldtEX4d"},{"type":"heading","depth":3,"position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"children":[{"type":"text","value":"Sustainability Playbook","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"a81Budfh0G"}],"identifier":"sustainability-playbook","label":"Sustainability Playbook","html_id":"sustainability-playbook","implicit":true,"key":"a8rWHLa2Un"},{"type":"div","children":[{"type":"image","url":"/build/susPB_logo-cd117769a498d8dce7b840656e07ad12.svg","alt":"UC OSPO Logo with the words 'sustainability playbook' in stylized text","align":"center","class":"suspb-image","key":"dGatQS0q04","urlSource":"../static/images/ucsb/susPB_logo.svg"},{"type":"paragraph","position":{"start":{"line":85,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Since our recent survey showed that many open source contributors are struggling\nwith project sustainability, we plan to create a website with resources on the topic.\nWe are calling it the “Sustainability Playbook”. It will be tailored to UC throughout,\npointing readers to the relevant staff offices that can help, with tips and tricks for\nnavigating UC’s administrative channels. The playbook will be rich with interviews\nfrom UC developers and project stewards discussing how they have so far succeeded in\nsustaining an open source project.","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"oT3WPnA8Ds"}],"key":"o6wYSUUARC"}],"class":"ucsb-clearfix","key":"Ebw2EQNfvv"}],"key":"UmhCFXdlyW"}],"class":"ucsb-panel-light","key":"fH0wQVupep"},{"type":"comment","value":" PAST PROJECTS ","key":"P7jrokysoc"},{"type":"div","children":[{"type":"card","children":[{"type":"cardTitle","children":[{"type":"text","value":"Past projects","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"hFZN7UcOK1"}],"key":"ytzSEANKwT"},{"type":"heading","depth":3,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"UC Open Source Survey","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"Sd4Fwqr8NZ"}],"identifier":"uc-open-source-survey","label":"UC Open Source Survey","html_id":"uc-open-source-survey","implicit":true,"key":"f3El1aQAuc"},{"type":"div","children":[{"type":"div","children":[{"type":"image","url":"/build/infographic_small_cr-9da54c467366cbb60637016250c8b851.png","alt":"Thumbnail preview of an infographic","align":"center","class":"ucsb-thumbnail-img","key":"UNznBwDFyZ","urlSource":"../static/images/ucsb/infographic_small_crop.png"}],"class":"ucsb-thumbnail-wrapper","key":"EROHIqx14a"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"Our team recently spearheaded a survey of nearly 300 open source contributors\nas part of the UC OSPO Network’s discovery activities. You can\n","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"JrQeMSXt0U"},{"type":"link","url":"https://ucospo.net/oss-resources/survey/","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"children":[{"type":"text","value":"read more about the UC Open Source Contributor Survey","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"yr1Oz8UDiH"}],"urlSource":"https://ucospo.net/oss-resources/survey/","key":"KG3CqiXoax"},{"type":"text","value":". The\npreprint is available now, and the paper is undergoing peer review.","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"XMNER6LE0q"}],"key":"qN1tHBcL5o"}],"class":"ucsb-clearfix","key":"oTcKBFZ0Zr"}],"key":"xKfBTMQqUF"}],"class":"ucsb-panel-dark","key":"wo17HeL8No"},{"type":"heading","depth":2,"position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"What’s the status of the UCSB OSPO?","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"FpkJuqt6Ad"}],"identifier":"whats-the-status-of-the-ucsb-ospo","label":"What’s the status of the UCSB OSPO?","html_id":"whats-the-status-of-the-ucsb-ospo","implicit":true,"key":"Bm2PEdxODD"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"At present, UCSB does not have a dedicated Open Source Programs Office. Rather,\nwe have a cross-functional team of UCSB staff with knowledge and expertise in\nopen source who are developing the strategies, know-how, and connections needed\nto create an OSPO.","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"z0L1jtOXFX"}],"key":"eakentxQ2P"},{"type":"paragraph","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"children":[{"type":"text","value":"We envision that the UCSB OSPO will:","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"NW7Lp2caxt"}],"key":"vJxobG8RzQ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":139,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Help students, faculty, and staff to exchange knowledge and build connections,","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"tVfcFrFTLc"}],"key":"c2vZiAzrBM"}],"key":"nXahcIxTS4"},{"type":"listItem","spread":true,"position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Promote open source awareness on campus,","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"s385GyWrph"}],"key":"coa0uvBce0"}],"key":"VGVmZ9FP3J"},{"type":"listItem","spread":true,"position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Advise on open source licenses,","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"key":"tsyCR5nC2o"}],"key":"keFICB3Cau"}],"key":"X8FyfsmcXu"},{"type":"listItem","spread":true,"position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Help our campus to leverage the full potential of open source,","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"m5ZgU8TdQQ"}],"key":"BWAmjgmTSl"}],"key":"CCRzIAEryb"},{"type":"listItem","spread":true,"position":{"start":{"line":143,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"And more!","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"key":"kLNaj9KbW6"}],"key":"qqa3j7RpEZ"}],"key":"aCs0lEi9jy"}],"key":"ybqwK5lYDr"},{"type":"paragraph","position":{"start":{"line":145,"column":1},"end":{"line":147,"column":1}},"children":[{"type":"text","value":"Building on the work of the Open Source Programs Team, the OSPO will draw on\nresources developed by the UC OSPO Network, and its priorities will be shaped by\nboth UC leadership and the UCSB open source community.","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"QOstj3HDH4"}],"key":"WsqD5m8Ztg"},{"type":"paragraph","position":{"start":{"line":149,"column":1},"end":{"line":151,"column":1}},"children":[{"type":"text","value":"The current UCSB open source programs team includes staff members at the UCSB\nLibrary, and we expect that the Library will continue to be the center of\ngravity for this work for the foreseeable future.","position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"key":"itSR3CEo5X"}],"key":"JkrQbrnJM1"},{"type":"heading","depth":2,"position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"Get connected","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"nmEztwPe8Z"}],"identifier":"get-connected","label":"Get connected","html_id":"get-connected","implicit":true,"key":"sH0V4d86L0"},{"type":"comment","value":" ::::{div}\n:class: ospo-img\n\n<img src=\"../static/images/ucsb/UCSB-ospo.png\"\n     alt=\"UCSB open source programs logo\" />\n:::: ","key":"C4LAK07R45"},{"type":