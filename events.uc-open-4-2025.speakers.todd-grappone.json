{"version":3,"kind":"Article","sha256":"6778156dd105e5b53bb773b65826e72e243bf4b04fee055d4ece295b489dde07","slug":"events.uc-open-4-2025.speakers.todd-grappone","location":"/events/uc-open-4-2025/speakers/todd-grappone.md","dependencies":[],"frontmatter":{"title":"Todd Grappone","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/todd-grappone.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/todd-grappone.md","thumbnail":"/uc-ospo-network.github.io/build/todd-grappone-084b983558e3f34b73c22f8a59fa0069.jpeg","exports":[{"format":"md","filename":"todd-grappone.md","url":"/uc-ospo-network.github.io/build/todd-grappone-ef7173bfffd02131b8197a6d9aa88a13.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/uc-ospo-network.github.io/build/todd-grappone-084b983558e3f34b73c22f8a59fa0069.jpeg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"EOsEaLFWUx","urlSource":"headshots/todd-grappone.jpeg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Todd Grappone is a librarian and information technology expert with over twenty years of experience in academic institutions.\nHe is the Associate University Librarian for Digital Initiatives & Information Technology, Research and Development at UCLA.\nHe is responsible for ensuring that the library maintains a reliable, scalable, and sustainable environment.\nHe oversees five enterprise-wide departments to promote and coordinate public services and develop connections with research faculty to meet their evolving needs.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"X7pGQcQL5y"}],"key":"hV4p0Kh2Ze"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Todd has worked to develop and oversee many large-scale initiatives in digital preservation, global collections development, and post-custodial community archives.\nHe is the driving force behind some of the most impactful digital library programs in the world like the Modern Endangered Archives Program, a celebrated and critically important program that works to meet the urgent need of preserving at risk cultural heritage across the globe.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"eOeGOsOqo8"}],"key":"EQdrewvV7Y"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"JJ3sEeu7e0"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"uY2SaTLXlL"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/what-is-open","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Open S#####? Understanding What is Meant by ‘Open’","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"rfiW4EQAu0"}],"urlSource":"../sessions/what-is-open.md","dataUrl":"/events.uc-open-4-2025.sessions.what-is-open.json","internal":true,"protocol":"file","key":"PwPxIC0o9F"}],"key":"dKSODWk9ha"}],"key":"i6C3U7mHry"}],"key":"M636ftl8Aj"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}