{"version":3,"kind":"Article","sha256":"1b7fbd3297992956f6ec7dc86a32fb10590e6c9f3ae13502fe2203954d834db5","slug":"events.uc-open-4-2025.speakers.jarrod-millman","location":"/events/uc-open-4-2025/speakers/jarrod-millman.md","dependencies":[],"frontmatter":{"title":"Jarrod Millman","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/jarrod-millman.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/jarrod-millman.md","thumbnail":"/build/jarrod-millman-ec99f62791e03ea53b0db4f14a8d7510.png","exports":[{"format":"md","filename":"jarrod-millman.md","url":"/build/jarrod-millman-72f314f16407a648b24e8d08f1a9d7d4.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/jarrod-millman-ec99f62791e03ea53b0db4f14a8d7510.png","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"RJoz8Kruqa","urlSource":"headshots/jarrod-millman.png"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Jarrod Millman is a Senior Open Source Scientific Python Developer at BIDS and the Executive Director for ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"WwG88lwABD"},{"type":"link","url":"https://bids.berkeley.edu/programs-initiatives/open-source-program-office-ospo","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Berkeley’s Open Source Program Office","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"TTutILM7YB"}],"urlSource":"https://bids.berkeley.edu/programs-initiatives/open-source-program-office-ospo","key":"uyIItjA6nJ"},{"type":"text","value":" (OSPO).\nWith a background in computer science, mathematics, and statistics, and degrees from Cornell and Berkeley, Millman is a founding member of the scientific Python ecosystem.\nHis primary focus is on developing and sustaining open-source, community-owned scientific software tools.\nMillman serves on the steering council of NetworkX, is a core developer of scikit-image, and was an early contributor to NumPy, SciPy, and scikit-learn.\nHe has co-founded several influential initiatives to advance open and reproducible research, including the Scientific Python project, the nonprofit NumFOCUS, and the Neuroimaging in Python project.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"md9Rg5KbS6"}],"key":"FCGw5fqZr2"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"o9v6DUhirK"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"hzhlqhvzBD"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/what-is-open","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Open S#####? Understanding What is Meant by ‘Open’","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"TbqK7hHizJ"}],"urlSource":"../sessions/what-is-open.md","dataUrl":"/events.uc-open-4-2025.sessions.what-is-open.json","internal":true,"protocol":"file","key":"uORlxhNRqQ"}],"key":"JbjfXQ91g2"}],"key":"Tr9H0Fk57m"}],"key":"EmYuvwppoU"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}