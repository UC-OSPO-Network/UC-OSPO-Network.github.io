ext","value":" (OSPO).\nWith a background in computer science, mathematics, and statistics, and degrees from Cornell and Berkeley, Millman is a founding member of the scientific Python ecosystem.\nHis primary focus is on developing and sustaining open-source, community-owned scientific software tools.\nMillman serves on the steering council of NetworkX, is a core developer of scikit-image, and was an early contributor to NumPy, SciPy, and scikit-learn.\nHe has co-founded several influential initiatives to advance open and reproducible research, including the Scientific Python project, the nonprofit NumFOCUS, and the Neuroimaging in Python project.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"DQVme9FKmE"}],"key":"o8ITrxKXMv"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"LVcIu2NuLY"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"YmWf0EvqKw"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/what-is-open","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Open S#####? Understanding What is Meant by ‘Open’","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"wPfMfvCfJK"}],"urlSource":"../sessions/what-is-open.md","dataUrl":"/events.uc-open-4-2025.sessions.what-is-open.json","internal":true,"protocol":"file","key":"zoqcs3h0ff"}],"key":"UyLcM7XQTz"}],"key":"viLstz6M2J"}],"key":"rIRfkHnrSy"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}