{"version":3,"kind":"Article","sha256":"1b7fbd3297992956f6ec7dc86a32fb10590e6c9f3ae13502fe2203954d834db5","slug":"events.uc-open-4-2025.speakers.jarrod-millman","location":"/events/uc-open-4-2025/speakers/jarrod-millman.md","dependencies":[],"frontmatter":{"title":"Jarrod Millman","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/jarrod-millman.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/jarrod-millman.md","thumbnail":"/build/jarrod-millman-afc6749634fa392013bcebc1bbcf54ed.png","exports":[{"format":"md","filename":"jarrod-millman.md","url":"/build/jarrod-millman-9165d24dd763b121387253ff25f7b946.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/jarrod-millman-afc6749634fa392013bcebc1bbcf54ed.png","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"bsxAxiqAoU","urlSource":"headshots/jarrod-millman.png"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Jarrod Millman is a Senior Open Source Scientific Python Developer at BIDS and the Executive Director for ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"OyzDaYOjzz"},{"type":"link","url":"https://bids.berkeley.edu/programs-initiatives/open-source-program-office-ospo","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Berkeley’s Open Source Program Office","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"BUnT731Czb"}],"urlSource":"https://bids.berkeley.edu/programs-initiatives/open-source-program-office-ospo","key":"RPGkwKS1av"},{"type":"text","value":" (OSPO).\nWith a background in computer science, mathematics, and statistics, and degrees from Cornell and Berkeley, Millman is a founding member of the scientific Python ecosystem.\nHis primary focus is on developing and sustaining open-source, community-owned scientific software tools.\nMillman serves on the steering council of NetworkX, is a core developer of scikit-image, and was an early contributor to NumPy, SciPy, and scikit-learn.\nHe has co-founded several influential initiatives to advance open and reproducible research, including the Scientific Python project, the nonprofit NumFOCUS, and the Neuroimaging in Python project.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"YBvkTnU4iW"}],"key":"Lv590yEFrm"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"KLbjvSZLen"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"rhP77qJ8Gg"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/what-is-open","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Open S#####? Understanding What is Meant by ‘Open’","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"m3snhpxdW9"}],"urlSource":"../sessions/what-is-open.md","dataUrl":"/events.uc-open-4-2025.sessions.what-is-open.json","internal":true,"protocol":"file","key":"WHi6gJcsLt"}],"key":"EpSVT67oYr"}],"key":"ho0h2f2vA4"}],"key":"KTQH8ahNa5"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}