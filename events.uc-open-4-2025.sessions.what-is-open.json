:"a26s4NrxKj"}],"key":"J2wgmLfBqU"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Description","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"sbkkGId6gc"}],"identifier":"description","label":"Description","html_id":"description","implicit":true,"key":"SF54OqnI52"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"There are many dimensions of openness, and open source means different things in different contexts.\nIn this panel the speakers will discuss open source software, open (and FAIR) data, open access, accessibility and inclusion, and citizen participation in scholarly communications.\nThey will share how they came to be working in an open space, and discuss how open source can be misunderstood.\nThere will be lots of time for questions and discussion with the audience to identify who doesn’t see themselves represented in open communities and what would need to change to see themselves belonging.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"QZuOlEsdJS"}],"key":"aXHqQ7kizJ"}],"key":"CAeyEH12bi"}],"key":"EW6GcenzbM"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}