{"version":3,"kind":"Article","sha256":"ff2f6d8ee8e65dd059ca3a6ef3e5877f6da6b9e83662da426dce5d50a0af87f8","slug":"events.uc-open-2026.talks.oact-right-to-replicate","location":"/events/uc-open-2026/talks/oact-right-to-replicate.md","dependencies":[],"frontmatter":{"title":"Open Analytics Control Tower (OACT): A \"Right to Replicate\" Prototype for Infrastructure Risk","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/oact-right-to-replicate.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/oact-right-to-replicate.md","exports":[{"format":"md","filename":"oact-right-to-replicate.md","url":"/build/oact-right-to-replic-87a42af2db55d6a5f70494758159434f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"wqiu3zeQM2"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"Lxg0RSsg9E"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"OACT is an open-source, public-data decision-support prototype designed to help stakeholders detect, investigate, and quantify infrastructure disruption risk during extreme weather events (e.g., flooding and atmospheric river scenarios). This talk presents a reproducible “Right to Replicate” architecture: public data ingestion, auditable transformations, transparent scoring, and an evidence-first workflow designed for responsible reuse by universities and public-sector partners.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Ou5ZmVqEZx"}],"key":"V3p8Q5tb0Q"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"We will walk through the end-to-end pipeline (signals → features → risk scoring → recommended actions) and highlight design choices that improve reproducibility and governance, such as dataset lineage, assumptions logging, and decision traceability. By focusing on “auditability by default,” OACT addresses the critical gap between opaque proprietary risk models and the need for transparent, accessible tools in public-sector resilience planning. Attendees will leave with a concrete pattern for building analytics prototypes that bridge research, open infrastructure, and real-world decision needs.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"uoQY0TL3jC"}],"key":"WgSyN3aFZE"},{"type":"thematicBreak","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"iG8HNvOse0"},{"type":"heading","depth":3,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Yidan (Lena) Hu | Independent Researcher","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"O33IZrAsfg"}],"identifier":"yidan-lena-hu-independent-researcher","label":"Yidan (Lena) Hu | Independent Researcher","html_id":"yidan-lena-hu-independent-researcher","implicit":true,"key":"SeyWwpwMfb"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Bio coming soon.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"PdhSGZevCm"}],"key":"QFf0rjfq9y"}],"key":"B2bh3VMbW9"},{"type":"heading","depth":3,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Laisi (Maggie) Ma | Independent Researcher","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"jgkWw1d5a1"}],"identifier":"laisi-maggie-ma-independent-researcher","label":"Laisi (Maggie) Ma | Independent Researcher","html_id":"laisi-maggie-ma-independent-researcher","implicit":true,"key":"w3tmGzHLjQ"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Bio coming soon.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"OgkGvwfV5B"}],"key":"fYobeoIXjP"}],"key":"C7ckEn5zmi"},{"type":"heading","depth":3,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Hao He | Independent Researcher","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"KBqMD0BfUX"}],"identifier":"hao-he-independent-researcher","label":"Hao He | Independent Researcher","html_id":"hao-he-independent-researcher","implicit":true,"key":"mMqZtFmr5a"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Bio coming soon.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"tCtszBPCCB"}],"key":"jgtQZSMNfp"}],"key":"aEBhh54dPs"},{"type":"heading","depth":3,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Yuan-Jiun (David) Sung | Independent Researcher (Principal Investigator, remote)","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"SEQIc8lcYU"}],"identifier":"yuan-jiun-david-sung-independent-researcher-principal-investigator-remote","label":"Yuan-Jiun (David) Sung | Independent Researcher (Principal Investigator, remote)","html_id":"yuan-jiun-david-sung-independent-researcher-principal-investigator-remote","implicit":true,"key":"AaOaSN6qqC"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Yuan-Jiun (David) Sung is the Principal Investigator and Lead Architect for the Open Analytics Control Tower (OACT). A senior data professional with over a decade of experience architecting large-scale intelligence systems for top-tier technology and financial institutions, he specializes in translating complex environmental signals into actionable, auditable risk decisions. His current independent research aligns with federal and state resilience initiatives, providing open, reproducible infrastructure to protect critical supply chains and “Missing Middle” operators from climate-driven failures. He holds Master’s degrees in Software Management and Electrical and Computer Engineering from Carnegie Mellon University and Purdue University.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"RhW4hgAAc4"}],"key":"koP9zkaM0M"}],"key":"Wh2JDel8bS"}],"key":"yBmcv1CGAQ"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}