rt":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"ieKLHMCfWB"}],"identifier":"ways-to-contribute","label":"Ways to Contribute","html_id":"ways-to-contribute","implicit":true,"key":"dPVcVnAWy7"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"Brainstorm ways that contributors can help the project beyond the obvious code contributions. Maintainers often serve multiple functions and roles on a project, not just technical decision making (which is harder to delegate) but also marketing, content creation, technical writing, project management, community management, and more! If you would accept help with any of these tasks, call that out to attract a more diverse set of contributors with complementary skillets to your existing contributors.","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"OuSpduZMmM"}],"key":"oC1yc4OrPK"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Don’t forget to assess maintainer availability and be realistic about which type of contributions you are willing to shepherd through your processes to ensure contributors are successful. Large vendor-backed projects are more likely to have time to mentor and assist people new to open source or programming. We encourage you to start with a limited list of paths to contributing, and expand them over time as your project grows.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"lCxlVRywFK"}],"key":"kzZaGWk9aa"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Think about your project’s contribution ladder, and if it makes sense, encourage people to review pull requests as a way to contribute as well.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"vvBJfJXySI"}],"key":"dha5EvXZaQ"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Often security-related contributions, such as reporting security issues, are handled by a specific security process. Include a link to your security reporting process so that people can find and follow it.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"d1gDzVMkCq"}],"key":"R6JAHWtXUx"},{"type":"heading","depth":2,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Come to Community Calls","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"CpJkC7Rfoi"}],"identifier":"come-to-community-calls","label":"Come to Community Calls","html_id":"come-to-community-calls","implicit":true,"key":"higHr96PBe"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"If your project has open ","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"MkpdJnCGdH"},{"type":"link","url":"https://opensource.com/open-organization/16/1/community-calls-will-increase-participation-your-open-organization","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"community calls","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"DbxTRknHgY"}],"urlSource":"https://opensource.com/open-organization/16/1/community-calls-will-increase-participation-your-open-organization","key":"aM3vMgXt7f"},{"type":"text","value":", encourage contributors to attend and customize the template with your meeting information. The more contributors interact with your project, the more likely they are to find meaningful ways to contribute and stick around.","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"K4qEyLVi5g"}],"key":"aFAFuEPp6n"},{"type":"heading","depth":2,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Finding an Issue","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"nt1s1kDQHw"}],"identifier":"finding-an-issue","label":"Finding an Issue","html_id":"finding-an-issue","implicit":true,"key":"oWl4h7lXlG"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Often contributors want to help out but don’t know where to start. If you have an issue labeling strategy, explain it here. For example, “good first issue” or “help wanted” for new contributors.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"Cne2N114hy"}],"key":"tvtpOUVCR5"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"If you copied our template repo, your repo came with a few issue templates to help new contributors know what information you need in an issue, and you can find them in the ","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"TAdbpR5SEp"},{"type":"inlineCode","value":".github/ISSUE_TEMPLATE","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"Nag5PyGcjn"},{"type":"text","value":" directory at the project root. Check out GitHub’s ","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"Hry3P1FIrv"},{"type":"link","url":"https://docs.github.com/en/communities/using-templates-to-encourage-useful-issues-and-pull-requests/about-issue-and-pull-request-templates","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"instructions for creating/editing/removing issue templates","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"fkDnNhW2Ti"}],"urlSource":"https://docs.github.com/en/communities/using-templates-to-encourage-useful-issues-and-pull-requests/about-issue-and-pull-request-templates","key":"TZPQLVzhEE"},{"type":"text","value":".","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"rIwD4XLgwq"}],"key":"Hv8roXlGVL"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Let contributors know how they should indicate that they want to work on an issue, such as commenting with “I would like to work on this”.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"fv0JqrhFC5"}],"key":"X4zADSt6sL"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"If your project doesn’t always have issues labeled and ready to find, and you are willing to help find suitable issues, let new contributors know how to ask for something to work on.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"vljl20gtvv"}],"key":"oGMgAIlByG"},{"type":"heading","depth":2,"position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Setting up a Dev Environment","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"WIsB0FK4I5"}],"identifier":"setting-up-a-dev-environment","label":"Setting up a Dev Environment","html_id":"setting-up-a-dev-environment","implicit":true,"key":"MA1pLjysgO"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Provide enough information so that someone can find your project on the weekend and get set up, build the code, test it, and submit a pull request successfully without having to ask any questions. If there is a one-off tool they need to install, common error people run into, or useful script they should run, document that here.","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"N4ewgQYXrx"}],"key":"YAjw44rL4l"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Document any necessary tools, such as linters, or recommended IDE extensions. You don’t have to document the beginner’s guide to these tools, but how they are used within the scope of your project. This is a great place to include links to new user documentation videos and examples to get people started and understanding how to use the project","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"ZVt9HyRje6"}],"key":"HZbwIm4AyF"},{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"You should explain how to do at least these basic tasks:","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"uwtlG6AHk3"}],"key":"u5XNugwZKt"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":58,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Get the source code","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"CN2v106If5"}],"key":"fjC4hANfhT"}],"key":"uQg0m32HmA"},{"type":"listItem","spread":true,"position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Retrieve any dependencies","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"BjXoHq6JGs"}],"key":"NXrzeKpLsX"}],"key":"nAKiCG7sb8"},{"type":"listItem","spread":true,"position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Build the source code","position":{"start":{"line":60,"column":1},"end":{"line":60,"