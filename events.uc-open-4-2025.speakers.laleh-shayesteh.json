{"version":3,"kind":"Article","sha256":"316afadcaae9aca7101689e17d56e5646f68eeeec4a5c6aead1875fe3048c420","slug":"events.uc-open-4-2025.speakers.laleh-shayesteh","location":"/events/uc-open-4-2025/speakers/laleh-shayesteh.md","dependencies":[],"frontmatter":{"title":"Laleh Shayesteh","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/laleh-shayesteh.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/laleh-shayesteh.md","thumbnail":"/build/laleh-shayesteh-cf13fc58200756d9fc1449b809dba32f.png","exports":[{"format":"md","filename":"laleh-shayesteh.md","url":"/build/laleh-shayesteh-3f0c823dc6e42741a45fae003db8b002.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/laleh-shayesteh-cf13fc58200756d9fc1449b809dba32f.png","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"dWqzLORtZ8","urlSource":"headshots/laleh-shayesteh.png"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Laleh is the Director of Intellectual Property and Administration for the Office of Technology Licensing where she develops UC Berkeley’s IP strategy and oversees licensing for life sciences, chemistry, medical instruments, physical sciences, engineering, and software technologies. Additionally, she handles trademark and copyright matters, open source compliance, and government grant and contract IP matters.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Z1Fxjh5T9X"}],"key":"PXbcdQQEpt"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Laleh is a trained scientist and worked for several years in research before practicing law. Prior to joining UC Berkeley, she performed population genetics research at Stanford, pediatric brain tumor research and ovarian cancer research at UCSF, brain tumor research at University of Chicago, and comparative genomics research at Exelixis. She then embarked on a law career and became a patent agent at Exelixis, followed by a director of IP and assistant general counsel for IP matters at SRI.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"PzrW6hMchE"}],"key":"WnJvc5j724"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Laleh holds a Ph.D. in Biophysics from UC San Francisco and a J.D. from Concord Law School. She is a member of California State Bar and is also registered to practice before the US Patent and Trademark Office.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"u4rApQ8IcO"}],"key":"eicQN2CYT4"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"xaYCeCA0Od"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"tGQOqNLJom"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/technology-transfer","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Technology Transfer and Impact of Open Source","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"l6lJeI7BEY"}],"urlSource":"../sessions/technology-transfer.md","dataUrl":"/events.uc-open-4-2025.sessions.technology-transfer.json","internal":true,"protocol":"file","key":"TxZ7IcwEnL"}],"key":"IsWlM8ziES"}],"key":"hnPAjN7Aa4"}],"key":"iyobwHxbg0"},"references":{