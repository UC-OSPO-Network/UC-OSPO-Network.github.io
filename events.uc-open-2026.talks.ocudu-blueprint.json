{"version":3,"kind":"Article","sha256":"c0f56768a80fdf8038453062da87a68fc3afa751e754d43601247c041753d499","slug":"events.uc-open-2026.talks.ocudu-blueprint","location":"/events/uc-open-2026/talks/ocudu-blueprint.md","dependencies":[],"frontmatter":{"title":"The OCUDU Blueprint: A New Paradigm for Collaboration in Open Source Innovation","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-2026/talks/ocudu-blueprint.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-2026/talks/ocudu-blueprint.md","thumbnail":"/build/ranny-haiby-6b3c8a7739ebc90980fed659d90ae5a1.jpeg","exports":[{"format":"md","filename":"ocudu-blueprint.md","url":"/build/ocudu-blueprint-5968ef99c0554cf8ddc37dd93f91712c.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Abstract","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"YjP48TP7bW"}],"identifier":"abstract","label":"Abstract","html_id":"abstract","implicit":true,"key":"pcMqHL5M0u"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The rapid evolution of 5G, 6G, and beyond requires a radical departure from traditional, closed-source proprietary development. This session introduces OCUDU (Open Central Unit / Distributed Unit), a pioneering initiative designed to accelerate wireless innovation by bridging the gap between industry, academia, and government.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"kX7iRaAjx0"}],"key":"bcbxY8d90p"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"At its core, OCUDU serves as a robust Open Source research platform, allowing academic researchers to move beyond theoretical simulations into real-world deployments. For students, it provides a “living lab” environment, fostering a new generation of engineers proficient in disaggregated RAN (Radio Access Network) architectures and cloud-native telecommunications.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"RI3Nx3RAoK"}],"key":"XbDD5iD0r5"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"We will explore the Three-way collaboration model that powers OCUDU, illustrating how:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"qjQ73cndcz"}],"key":"qpYx6ulPXz"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":13,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Government entities leverage the project to ensure national security and technological sovereignty.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"IoTknKMtwZ"}],"key":"ENqpO2VtUd"}],"key":"s20xHNziYe"},{"type":"listItem","spread":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Industry partners accelerate time-to-market and reduce R&D costs through shared codebases.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"jPP27YBbMj"}],"key":"dA5sjk29qa"}],"key":"h9YYEUeNs2"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Academia gains access to carrier-grade stacks for high-impact research and education.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"vMmEXVlLj4"}],"key":"k427M9nA2Y"}],"key":"sGhfdKpQWx"}],"key":"NpARXBxWzF"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"The session will conclude with a recipe for how this collaborative framework creates sustainable commercial opportunities and serves as a blueprint for future large-scale open-source initiatives across academia and the broader tech ecosystem.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"H200KbHLP7"}],"key":"bvcUwUfnPj"},{"type":"thematicBreak","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"IZWX5Cb2xX"},{"type":"div","children":[{"type":"image","url":"/build/ranny-haiby-6b3c8a7739ebc90980fed659d90ae5a1.jpeg","alt":"Ranny Haiby","align":"center","class":"speaker-bio-img","key":"toGCABRG6F","urlSource":"./speaker-headshots/ranny-haiby.jpeg"},{"type":"heading","depth":3,"position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"Ranny Haiby | The Linux Foundation","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"PrMMM2bsSI"}],"identifier":"ranny-haiby-the-linux-foundation","label":"Ranny Haiby | The Linux Foundation","html_id":"ranny-haiby-the-linux-foundation","implicit":true,"key":"wSUr1B2mqt"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Ranny Haiby serves as the Chief Technology Officer (CTO) for Networking, Edge, and Access at ","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"ZXT5UMgj8E"},{"type":"link","url":"https://lfnetworking.org","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"The Linux Foundation","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"Ioo96YV3UZ"}],"urlSource":"https://lfnetworking.org","key":"G6PChxIzdp"},{"type":"text","value":", where he drives technical innovation and fosters synergies across critical open-source projects. A software industry veteran with over two decades of experience, Haiby specializes in network automation, cloud-native transformation, and the intersection of open standards and open-source software. Prior to joining the Linux Foundation in 2022, he held senior leadership roles including Director of Open Source at Samsung Research America and Distinguished Member of the Technical Staff at Nokia.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"hglhFfZ2wG"}],"key":"o12e8CVDJB"}],"class":"speaker-bio","key":"LAVKtOE1tb"}],"key":"kwLsdwGpgA"}],"key":"dLqQLEx1X9"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}