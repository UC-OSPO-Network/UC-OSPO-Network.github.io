key":"Aiz9rFV4VF"},{"type":"listItem","spread":true,"position":{"start":{"line":30,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Advocating for or encouraging any of the above","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"yUv3jX1HZW"}],"key":"uo7XzhMiIZ"}],"key":"BRIG5vRNJo"}],"key":"bZ4e5XPQxE"},{"type":"heading","depth":2,"position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Photography and recording","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"Ei6stazTer"}],"identifier":"photography-and-recording","label":"Photography and recording","html_id":"photography-and-recording","implicit":true,"key":"r8ruMxFoZX"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Some UC OSPO Network events may be recorded and published on the UC OSPO Network YouTube channel. When this is the case, speakers will be informed in advance and asked to sign media release forms.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"QW5qCXZBDt"}],"key":"LRLXcE5pKE"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Attendees may take photos and short clips in session rooms and common areas. If someone asks not to be photographed or recorded, respect that immediately. Event organizers may designate certain spaces or times as no-photography zones.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"IgcOOkxj9U"}],"key":"xxPb5zemRG"},{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Speakers and presenters","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"OKiMBO3biP"}],"identifier":"spea