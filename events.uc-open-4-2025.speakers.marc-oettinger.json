{"version":3,"kind":"Article","sha256":"64ebd17d34eb715be50540460ec2ab278f14fe9262f60b6d5f56a2c5e61fcf87","slug":"events.uc-open-4-2025.speakers.marc-oettinger","location":"/events/uc-open-4-2025/speakers/marc-oettinger.md","dependencies":[],"frontmatter":{"title":"Marc Oettinger","github":"https://github.com/UC-OSPO-Network/ucospo.net","copyright":"2024","numbering":{"title":{"offset":1}},"source_url":"https://github.com/UC-OSPO-Network/ucospo.net/blob/main/events/uc-open-4-2025/speakers/marc-oettinger.md","edit_url":"https://github.com/UC-OSPO-Network/ucospo.net/edit/main/events/uc-open-4-2025/speakers/marc-oettinger.md","thumbnail":"/build/marc-oettinger-7cce9c641ad00555daa27e8c11db96af.jpg","exports":[{"format":"md","filename":"marc-oettinger.md","url":"/build/marc-oettinger-7aada1696ae747a5cc917f32635b422e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"image","url":"/build/marc-oettinger-7cce9c641ad00555daa27e8c11db96af.jpg","alt":"Speaker photo","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"hKOAmrnRcj","urlSource":"headshots/marc-oettinger.jpg"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Marc Oettinger is Assistant Director of Innovation Transfer at University of California (UC), Santa Cruz. Marc is the primary intellectual property and licensing contact for physical sciences and engineering and software. Marc is responsible for all aspects of the intellectual property and licensing practice, including disclosure solicitation and intake, patent/software protection and management, industry outreach and engagement, and licensing. Prior to UC Santa Cruz, Marc was senior licensing staff in University of Virginia’s Licensing & Ventures Group, including a liaison role to School of Engineering and Applied Science. Prior to that, he served as senior licensing staff in UC Berkeley’s Office of Intellectual Property & Industry Research Alliances. Marc’s work experience includes IP and licensing-related positions in federal, large industry, and startup entities.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"jFNO4qSybv"}],"key":"Hu9ofKMJKL"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Session","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"PSibUSLcZc"}],"identifier":"session","label":"Session","html_id":"session","implicit":true,"key":"Gvoyr2do2c"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"link","url":"/events/uc-open-4-2025/sessions/technology-transfer","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Technology Transfer and Impact of Open Source","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"nXGBZVPlIB"}],"urlSource":"../sessions/technology-transfer.md","dataUrl":"/events.uc-open-4-2025.sessions.technology-transfer.json","internal":true,"protocol":"file","key":"CakiOTZGqE"}],"key":"glHZ6kUgS5"}],"key":"RBXIktLmQd"}],"key":"PPji1qwY1l"},"references":{"cite":{"order":[],"data":{}}},"footer":{},"domain":"http://localhost:3000"}